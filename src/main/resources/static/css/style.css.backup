:root {
    --bg-0: #07111f;
    --bg-1: #0f1b32;
    --bg-2: #162846;
    --surface: rgba(10, 18, 35, 0.72);
    --surface-strong: rgba(15, 27, 50, 0.92);
    --surface-light: rgba(255, 255, 255, 0.08);
    --border: rgba(255, 255, 255, 0.12);
    --text: #ecf3ff;
    --muted: #98a7c2;
    --primary: #8bd3ff;
    --primary-strong: #4aa8ff;
    --accent: #7c8cff;
    --success: #4cd7a5;
    --danger: #ff7b8a;
    --shadow: 0 22px 60px rgba(0, 0, 0, 0.28);
    --radius-xl: 28px;
    --radius-lg: 20px;
    --radius-md: 14px;
    --radius-sm: 10px;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: Inter, "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    color: var(--text);
    background:
        radial-gradient(circle at top left, rgba(139, 211, 255, 0.24), transparent 28%),
        radial-gradient(circle at 80% 10%, rgba(124, 140, 255, 0.18), transparent 24%),
        linear-gradient(160deg, var(--bg-0), var(--bg-1) 45%, var(--bg-2));
    min-height: 100vh;
    line-height: 1.6;
    overflow-x: hidden;
}

body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
        linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.55), transparent 85%);
}

a {
    color: inherit;
}

img {
    max-width: 100%;
    display: block;
}

.container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 28px 20px 64px;
}

header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(6, 12, 24, 0.72);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    max-width: 1240px;
    margin: 0 auto;
    padding: 16px 20px;
}

.logo {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    cursor: pointer;
}

.logo::before {
    content: "";
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    box-shadow: 0 0 20px rgba(139, 211, 255, 0.65);
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
}

.nav-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    color: rgba(236, 243, 255, 0.88);
    background: transparent;
    transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    cursor: pointer;
}

.nav-links a:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
    color: #fff;
}

.auth-buttons {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 1.25rem;
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease;
}

.btn:hover {
    transform: translateY(-2px);
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary-strong), var(--accent));
    color: white;
    box-shadow: 0 16px 32px rgba(74, 168, 255, 0.28);
}

.btn-primary:hover {
    box-shadow: 0 18px 38px rgba(74, 168, 255, 0.35);
}

.btn-secondary {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text);
    border-color: rgba(255, 255, 255, 0.14);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.11);
}

.hero-shell,
.card,
.auth-card,
.product-card,
.chat-container,
.chat-wrapper,
.profile-content,
.profile-card,
.listing-item,
.message-modal,
.search-panel,
.surface-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
}

.card,
.auth-card,
.profile-content,
.profile-card,
.listing-item,
.surface-panel {
    padding: 1.5rem;
}

.card-header {
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: #fff;
}

.form-group {
    margin-bottom: 1.25rem;
}

label {
    display: block;
    margin-bottom: 0.45rem;
    font-weight: 600;
    color: rgba(236, 243, 255, 0.92);
}

input,
textarea,
select {
    width: 100%;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-md);
    background: rgba(4, 10, 22, 0.72);
    color: var(--text);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease, background 0.2s ease;
}

input::placeholder,
textarea::placeholder {
    color: rgba(152, 167, 194, 0.76);
}

input:focus,
textarea:focus,
select:focus {
    outline: none;
    border-color: rgba(139, 211, 255, 0.85);
    box-shadow: 0 0 0 4px rgba(74, 168, 255, 0.16);
    transform: translateY(-1px);
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
}

.product-card {
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(139, 211, 255, 0.28);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.32);
}

.product-image {
    width: 100%;
    height: 220px;
    object-fit: cover;
    background: linear-gradient(135deg, rgba(139, 211, 255, 0.18), rgba(124, 140, 255, 0.18));
}

.product-info {
    padding: 1rem 1.1rem 1.2rem;
}

.product-title {
    font-weight: 800;
    margin-bottom: 0.45rem;
    min-height: 44px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

.product-price {
    color: var(--primary);
    font-size: 1.15rem;
    font-weight: 800;
    margin-bottom: 0.45rem;
}

.product-seller {
    font-size: 0.88rem;
    color: var(--muted);
    margin-bottom: 0.7rem;
}

.product-category,
.condition-badge,
.listing-status {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(255, 255, 255, 0.08);
    color: var(--text);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.82rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
}

.auth-container {
    max-width: 460px;
    margin: 3rem auto;
}

.auth-card {
    position: relative;
    overflow: hidden;
}

.auth-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(139, 211, 255, 0.12), transparent 35%);
    pointer-events: none;
}

.auth-title {
    text-align: center;
    margin-bottom: 0.75rem;
    color: #fff;
    font-size: 1.9rem;
    font-weight: 900;
}

.auth-link {
    text-align: center;
    margin-top: 1rem;
    color: var(--muted);
}

.auth-link a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 700;
}

.auth-link a:hover {
    text-decoration: underline;
}

.alert {
    padding: 1rem 1.1rem;
    border-radius: var(--radius-md);
    margin-bottom: 1rem;
    border: 1px solid transparent;
    backdrop-filter: blur(10px);
}

.alert-success {
    background: rgba(76, 215, 165, 0.14);
    color: #c8ffe9;
    border-color: rgba(76, 215, 165, 0.25);
}

.alert-error {
    background: rgba(255, 123, 138, 0.14);
    color: #ffd4da;
    border-color: rgba(255, 123, 138, 0.25);
}

.loading {
    padding: 2rem;
    text-align: center;
    color: var(--muted);
}

.search-panel,
.hero-shell {
    padding: 1.5rem;
}

.products-grid,
.chat-container,
.chat-wrapper,
.profile-container,
.listing-item {
    animation: fadeUp 0.45s ease both;
}

.chat-container {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 0;
    min-height: 640px;
    overflow: hidden;
}

.chat-wrapper {
    display: grid;
    grid-template-columns: 300px 1fr;
    min-height: 680px;
    overflow: hidden;
}

.conversations-list,
.conversations-sidebar {
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    overflow-y: auto;
}

.conversation-item {
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
}

.conversation-item:hover {
    background-color: rgba(255, 255, 255, 0.06);
}

.conversation-item.active {
    background: linear-gradient(135deg, rgba(74, 168, 255, 0.16), rgba(124, 140, 255, 0.2));
}

.messages-area,
.messages-display {
    display: flex;
    flex-direction: column;
}

.messages-display,
.messages-area {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
}

.message {
    margin-bottom: 1rem;
    display: flex;
    gap: 0.5rem;
}

.message.sent {
    justify-content: flex-end;
}

.message-content {
    max-width: min(72%, 520px);
    padding: 0.85rem 1rem;
    border-radius: 18px;
    word-wrap: break-word;
    border: 1px solid rgba(255, 255, 255, 0.06);
}

.message.received .message-content {
    background: rgba(255, 255, 255, 0.08);
    color: var(--text);
}

.message.sent .message-content {
    background: linear-gradient(135deg, rgba(74, 168, 255, 0.98), rgba(124, 140, 255, 0.98));
    color: white;
}

.message-input {
    display: flex;
    gap: 0.75rem;
    padding: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.message-input input {
    flex: 1;
    margin: 0;
}

.message-input button {
    padding: 0.85rem 1.1rem;
}

.profile-container {
    display: grid;
    grid-template-columns: minmax(280px, 360px) 1fr;
    gap: 1.5rem;
    margin-top: 1.5rem;
}

.profile-picture {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary-strong), var(--accent));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    margin: 0 auto 1rem;
    box-shadow: 0 18px 40px rgba(74, 168, 255, 0.3);
}

.profile-name {
    font-size: 1.35rem;
    font-weight: 900;
    margin-bottom: 0.35rem;
}

.profile-college {
    color: var(--muted);
    font-size: 0.95rem;
    margin-bottom: 1rem;
}

.profile-rating {
    color: #ffd36b;
    font-size: 1rem;
    margin-bottom: 1rem;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1rem;
}

.stat-item {
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.07);
}

.stat-value {
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--primary);
}

.stat-label {
    font-size: 0.84rem;
    color: var(--muted);
    margin-top: 0.25rem;
}

.tabs {
    display: flex;
    gap: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
}

.tab-button {
    padding: 0.8rem 1.1rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--muted);
    font-weight: 700;
    border-bottom: 3px solid transparent;
    transition: all 0.2s ease;
}

.tab-button.active {
    color: #fff;
    border-bottom-color: var(--primary);
}

.tab-content {
    display: none;
}

.tab-content.active {
    display: block;
}

.form-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
}

.form-row.full {
    grid-template-columns: 1fr;
}

.btn-save,
.btn-logout {
    width: 100%;
    border: none;
    border-radius: 999px;
    padding: 0.9rem 1.2rem;
    font-weight: 800;
    color: white;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
}

.btn-save:hover,
.btn-logout:hover {
    transform: translateY(-2px);
    filter: brightness(1.03);
}

.btn-save {
    background: linear-gradient(135deg, var(--primary-strong), var(--accent));
    box-shadow: 0 16px 32px rgba(74, 168, 255, 0.28);
}

.btn-logout {
    background: linear-gradient(135deg, #ff6b81, #ff8a5b);
}

.read-only {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.9rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.08);
}

.listing-item {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1.25rem;
    margin-bottom: 1rem;
}

.listing-image {
    width: 160px;
    height: 160px;
    object-fit: cover;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, rgba(139, 211, 255, 0.18), rgba(124, 140, 255, 0.18));
}

.listing-title {
    font-size: 1.15rem;
    font-weight: 900;
    color: #fff;
}

.listing-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    font-size: 0.92rem;
    margin-top: 0.85rem;
}

.meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
}

.meta-label {
    color: var(--muted);
    font-size: 0.8rem;
}

.meta-value {
    font-weight: 800;
    color: #fff;
}

.listing-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 1rem;
}

.action-btn {
    padding: 0.7rem 1rem;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 800;
    transition: transform 0.2s ease, filter 0.2s ease;
}

.action-btn:hover {
    transform: translateY(-2px);
}

.btn-edit { background: rgba(139, 211, 255, 0.18); color: #dff5ff; }
.btn-mark-sold { background: rgba(255, 123, 138, 0.18); color: #ffd4da; }
.btn-delete { background: rgba(255, 255, 255, 0.08); color: #ecf3ff; }

.empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--muted);
}

.empty-state p {
    font-size: 1.05rem;
    margin-bottom: 1rem;
}

.status-available { background: rgba(76, 215, 165, 0.16); color: #c9ffe9; }
.status-sold { background: rgba(255, 123, 138, 0.16); color: #ffd4da; }
.status-pending { background: rgba(255, 214, 102, 0.16); color: #fff1bd; }

.conversation-name,
.chat-header-name,
.seller-name,
.product-seller {
    color: #fff;
}

.conversation-preview,
.conversation-time,
.seller-college,
.message-time,
.info-label,
.conversation-preview,
.conversation-time {
    color: var(--muted);
}

.no-selection {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--muted);
    font-size: 1.02rem;
}

@keyframes fadeUp {
    from {
        opacity: 0;
        transform: translateY(12px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@media (max-width: 1024px) {
    nav {
        align-items: flex-start;
        flex-direction: column;
    }

    .profile-container,
    .chat-container,
    .chat-wrapper {
        grid-template-columns: 1fr;
    }

    .conversations-list,
    .conversations-sidebar {
        border-right: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        max-height: 220px;
    }
}

@media (max-width: 768px) {
    .container {
        padding: 20px 14px 56px;
    }

    .nav-links {
        gap: 0.5rem;
    }

    .nav-links a,
    .btn {
        width: 100%;
    }

    .products-grid {
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .form-row,
    .listing-meta,
    .stats-grid {
        grid-template-columns: 1fr;
    }

    .listing-item {
        grid-template-columns: 1fr;
    }

    .listing-image {
        width: 100%;
        height: 220px;
    }

    .message-content {
        max-width: 86%;
    }
}
